# NextAuth
NEXTAUTH_SECRET=your-super-secret-jwt-secret-min-32-chars
NEXTAUTH_URL=http://localhost:3001

# GitHub API – used to read/write HTML files and trigger Vercel redeploy
# Create a token at: https://github.com/settings/tokens/new
# Required scopes: repo (Contents read & write)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_OWNER=your-github-username
GITHUB_REPO=your-repo-name
GITHUB_BRANCH=main

# Vercel Blob – used for image uploads
# Get this from: Vercel Dashboard → Storage → Blob store → Quickstart
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxxxxxx
